{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@assets/*": ["assets/*"],
      "@features/*": ["features/*"],
      "@navigation/*": ["navigation/*"],
      "@components/*": ["components/*"],
      "@unistyles/*": ["unistyles/*"],
      "@utils/*": ["utils/*"],
      "@constants/*": ["constants/*"],
      "@store/*": ["store/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}
